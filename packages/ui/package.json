{
  "name": "adysre",
  "version": "0.1.1",
  "type": "module",
  "description": "ADYSRE UI — React components, 448 original icons, gradients, patterns, textures and palettes for Next.js and React.",
  "keywords": [
    "react",
    "nextjs",
    "tailwindcss",
    "ui",
    "components",
    "icons",
    "gradients",
    "patterns",
    "textures",
    "design-system"
  ],
  "license": "MIT",
  "homepage": "https://github.com/abhisheksahu093/Adysre#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhisheksahu093/Adysre.git",
    "directory": "packages/ui"
  },
  "bugs": "https://github.com/abhisheksahu093/Adysre/issues",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./icons": "./src/icons/index.ts",
    "./gradients": "./src/gradients/index.ts",
    "./patterns": "./src/patterns/index.ts",
    "./textures": "./src/textures/index.ts",
    "./palettes": "./src/palettes/index.ts",
    "./blocks": "./src/blocks/index.ts",
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json",
    "./blocks/*": "./src/blocks/*.tsx"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "gen:icons": "tsx scripts/generate-icons.ts",
    "build": "pnpm gen:icons && tsc -p tsconfig.build.json && node scripts/build-assets.mjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "migrate:blocks": "tsx scripts/migrate-blocks.ts",
    "gen:blocks": "tsx scripts/generate-blocks-barrel.ts",
    "prepublishOnly": "node scripts/guard-publisher.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.3"
  },
  "peerDependencies": {
    "framer-motion": ">=11",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@adysre/config": "workspace:*",
    "@adysre/theme": "workspace:*",
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^20.16.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "framer-motion": "^12.42.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./icons": {
        "types": "./dist/icons/index.d.ts",
        "default": "./dist/icons/index.js"
      },
      "./gradients": {
        "types": "./dist/gradients/index.d.ts",
        "default": "./dist/gradients/index.js"
      },
      "./patterns": {
        "types": "./dist/patterns/index.d.ts",
        "default": "./dist/patterns/index.js"
      },
      "./textures": {
        "types": "./dist/textures/index.d.ts",
        "default": "./dist/textures/index.js"
      },
      "./palettes": {
        "types": "./dist/palettes/index.d.ts",
        "default": "./dist/palettes/index.js"
      },
      "./blocks": {
        "types": "./dist/blocks/index.d.ts",
        "default": "./dist/blocks/index.js"
      },
      "./styles.css": "./dist/styles.css",
      "./tokens.css": "./dist/tokens.css",
      "./dist.css": "./dist/adysre.css",
      "./package.json": "./package.json",
      "./blocks/*": {
        "types": "./dist/blocks/*.d.ts",
        "default": "./dist/blocks/*.js"
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "framer-motion": {
      "optional": true
    }
  }
}
