# ---- App ----
NODE_ENV=development

# ---- Web (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- API (apps/api) ----
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000
# Public base URLs used to build OAuth redirect URIs and the post-login bounce.
# API_PUBLIC_URL must be reachable by the browser and match the callback URL
# registered in each provider's console.
API_PUBLIC_URL=http://localhost:4000
APP_URL=http://localhost:3000

# ---- Database ----
DATABASE_URL=postgresql://adysre:adysre@localhost:5432/adysre?schema=public

# ---- Redis / BullMQ ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
COOKIE_DOMAIN=localhost

# ---- OAuth (Google / Microsoft / GitHub) ----
# Leave a pair blank to disable that provider - its button is auto-disabled.
# Callback URL to register with each provider (from API_PUBLIC_URL):
#   {API_PUBLIC_URL}/api/v1/auth/oauth/{google|microsoft|github}/callback
# See documents/OAUTH_SETUP.md for step-by-step setup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- AI ----
ANTHROPIC_API_KEY=
