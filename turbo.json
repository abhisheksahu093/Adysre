{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "adysre#build": {
      /*
       * The icon components and the blocks barrel are generated from the
       * catalogues, so a change to either has to re-run the build even though
       * nothing under `src/icons/generated` was edited by hand.
       */
      "dependsOn": ["^build"],
      "inputs": ["src/**", "scripts/**", "tsconfig*.json", "package.json"],
      "outputs": ["dist/**", "src/icons/generated/**", "src/blocks/index.ts"]
    },
    "gen:icons": { "cache": false },
    "gen:blocks": { "cache": false },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "db:generate": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
