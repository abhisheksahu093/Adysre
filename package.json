{
  "name": "adysre",
  "version": "0.1.0",
  "private": true,
  "description": "ADYSRE — enterprise AI-first Business Operating System",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @adysre/database db:generate",
    "db:migrate": "pnpm --filter @adysre/database db:migrate",
    "db:seed": "pnpm --filter @adysre/database db:seed",
    "db:studio": "pnpm --filter @adysre/database db:studio"
  },
  "devDependencies": {
    "@adysre/config": "workspace:^",
    "eslint": "^10.7.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
