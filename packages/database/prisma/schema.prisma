// ADYSRE database schema — see documents/DATABASE_ARCHITECTURE.md.
// Rules: PostgreSQL + Prisma single source of truth; shared-schema
// multi-tenancy via tenant_id; UUIDv7 PKs (app-generated); soft deletes;
// audit fields on every table; snake_case DB, camelCase TS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Core tenancy
// ---------------------------------------------------------------------------

model Organization {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Organization is the tenant root: tenantId mirrors id for uniform base cols.
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  users         User[]
  roles         Role[]
  permissions   Permission[]
  userRoles     UserRole[]
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]
  files          File[]
  settings       Setting[]
  designProjects DesignProject[]

  @@index([deletedAt])
  @@map("organizations")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String
  name         String
  passwordHash String?   @map("password_hash")
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at")

  organization  Organization   @relation(fields: [tenantId], references: [id])
  userRoles     UserRole[]
  sessions      Session[]
  notifications Notification[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@index([deletedAt])
  @@map("users")
}

// ---------------------------------------------------------------------------
// RBAC / ABAC
// ---------------------------------------------------------------------------

model Role {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  isSystem  Boolean   @default(false) @map("is_system")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  organization    Organization     @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  // `module:resource:action`, e.g. crm:lead:read
  key       String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  organization    Organization     @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([tenantId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.Uuid

  organization Organization @relation(fields: [tenantId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([tenantId, userId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Sessions, audit, notifications, files, settings
// ---------------------------------------------------------------------------

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  // Hash of the refresh token (rotation) — never store the raw token.
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ip               String?
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, resource, resourceId])
  @@map("audit_logs")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String
  title     String
  body      String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

model File {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  key       String
  name      String
  mimeType  String    @map("mime_type")
  size      Int
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])

  @@index([tenantId, deletedAt])
  @@map("files")
}

model Setting {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  key       String
  value     Json
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@map("settings")
}

// ---------------------------------------------------------------------------
// Design Playground — see documents/DESIGN_PLAYGROUND_PRD.md §6.1
// ---------------------------------------------------------------------------

model DesignProject {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  /// The full document (pages + flat node map), validated on read by
  /// `schema.parseDocument` before it reaches the canvas. JSONB rather than
  /// relational tables: the editor loads and saves whole documents, and a node
  /// row per shape would turn one autosave into thousands of statements.
  document  Json
  /// Mirrors document.schemaVersion so a migration can find stale rows without
  /// parsing every blob.
  schemaVersion Int   @default(1) @map("schema_version")
  /// Data-URI or object-store key for the card thumbnail; null until rendered.
  thumbnail String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])

  // The list view is always "this tenant's live projects, newest first".
  @@index([tenantId, deletedAt, updatedAt])
  @@map("design_projects")
}
