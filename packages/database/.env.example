# Copy to `.env` and point at your PostgreSQL server.
#
# The values below match `docker-compose.yml` (docker compose up -d postgres).
# If you run Postgres another way — Postgres.app, Homebrew, an existing server —
# use that server's own user, password and database instead.
DATABASE_URL="postgresql://adysre:adysre@localhost:5432/adysre?schema=public"
